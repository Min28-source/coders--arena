generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Problem { 
  id    Int     @id @default(autoincrement()) 
  title String
  description String
  constraints String[]
  examples String
  outputType String
  starterCode Json
  runnerCode Json
  testCases TestCase[]
}

model TestCase {
  id Int @id @default(autoincrement())
  problemId Int
  isHidden Boolean @default(true)
  input String
  output String
  problem Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)
}